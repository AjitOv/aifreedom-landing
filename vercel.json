{
  "functions": {
    "api/create-order.js": { "memory": 128, "maxDuration": 10 },
    "api/verify-payment.js": { "memory": 128, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/knowledge.md",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/rss.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/md/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/main.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/ads-consent.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/tools/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/security.txt",
      "destination": "/.well-known/security.txt"
    },
    {
      "source": "/businesstools/_next/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/_next/:path*"
    },
    {
      "source": "/businesstools/api/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/api/:path*"
    },
    {
      "source": "/businesstools/consultant",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/consultant"
    },
    {
      "source": "/businesstools/consultant/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/consultant/:path*"
    },
    {
      "source": "/businesstools/social-posts",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/social-posts"
    },
    {
      "source": "/businesstools/social-posts/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/social-posts/:path*"
    },
    {
      "source": "/businesstools/cold-email",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/cold-email"
    },
    {
      "source": "/businesstools/cold-email/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/cold-email/:path*"
    },
    {
      "source": "/businesstools/swot",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/swot"
    },
    {
      "source": "/businesstools/swot/:path*",
      "destination": "https://ai-business-consultant-chi.vercel.app/businesstools/swot/:path*"
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
